<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
               https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="tests.threebrs.sylius_analytics_plugin.context.ui.shop.visit_logging"
                 class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Ui\Shop\VisitLoggingContext"
                 public="true">
            <argument type="service" id="doctrine.orm.entity_manager"/>
            <argument type="service" id="behat.mink.default_session"/>
            <argument type="service" id="router"/>
        </service>

        <service id="tests.threebrs.sylius_analytics_plugin.context.ui.admin.view_request_logs"
                class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Ui\Admin\ViewRequestLogsContext"
                public="true">
            <argument type="service" id="behat.mink.default_session"/>
            <argument type="service" id="router"/>
        </service>

        <service id="tests.threebrs.sylius_analytics_plugin.context.ui.admin.dashboard_statistics"
                class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Ui\Admin\DashboardStatisticsContext"
                public="true">
            <argument type="service" id="behat.mink.default_session"/>
            <argument type="service" id="router"/>
        </service>

        <service id="tests.threebrs.sylius_analytics_plugin.context.ui.admin.product_request_counts"
                class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Ui\Admin\ProductRequestCountsContext"
                public="true">
            <argument type="service" id="behat.mink.default_session"/>
            <argument type="service" id="router"/>
        </service>

        <service id="tests.threebrs.sylius_analytics_plugin.context.ui.admin.request_filtering"
                class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Ui\Admin\RequestFilteringContext"
                public="true">
            <argument type="service" id="behat.mink.default_session"/>
            <argument type="service" id="router"/>
        </service>

        <service id="tests.threebrs.sylius_analytics_plugin.context.ui.shop.visitor_data_tracking"
                class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Ui\Shop\VisitorDataTrackingContext"
                public="true">
            <argument type="service" id="behat.mink.default_session"/>
            <argument type="service" id="router"/>
            <argument type="service" id="doctrine.orm.entity_manager"/>
            <argument type="service" id="sylius.repository.customer"/>
        </service>

        <service id="tests.threebrs.sylius_analytics_plugin.context.cli.console_command"
                class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Cli\ConsoleCommandContext"
                public="true">
            <argument type="service" id="kernel"/>
            <argument type="service" id="doctrine.orm.entity_manager"/>
            <argument type="service" id="sylius.repository.channel"/>
        </service>

        <service id="tests.threebrs.sylius_analytics_plugin.context.ui.admin.menu_integration"
                class="Tests\ThreeBRS\SyliusAnalyticsPlugin\Behat\Context\Ui\Admin\MenuIntegrationContext"
                public="true">
            <argument type="service" id="behat.mink.default_session"/>
            <argument type="service" id="router"/>
        </service>
    </services>
</container>
